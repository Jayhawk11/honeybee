{
  "version": "4.0-hybrid-optimized",
  "metadata": {
    "description": "Hybrid Z.AI (reasoning) + Groq (speed) multi-agent orchestration",
    "strategy": "Z.AI GLM-4.7/4.5/4.6V for complex reasoning, Groq for fast implementation",
    "costBreakdown": "-9/mo Z.AI +  Groq (unlimited free tier) = -9/mo total",
    "expectedPerformance": "3-4x faster implementations vs Z.AI only, same cost"
  },
  "providers": {
    "primary": "z-ai",
    "secondary": "groq",
    "fallback": "z-ai"
  },
  "agents": [
    {
      "name": "orchestrator-primary",
      "mode": "primary",
      "provider": "z-ai",
      "model": "glm-4-7",
      "description": "Master orchestrator - Z.AI GLM-4.7 for complex reasoning, task decomposition, state management.",
      "tools": ["Read", "Write", "Bash", "Task", "FunctionCall", "WebSearch"],
      "maxSteps": 25,
      "temperature": 0.25,
      "topP": 0.95,
      "maxTokens": 12000,
      "priority": "CRITICAL",
      "concurrencySlot": 1,
      "thinking": {
        "enabled": true,
        "mode": "preserved",
        "maxThinkingTokens": 8000
      }
    },
    {
      "name": "architect",
      "mode": "subagent",
      "provider": "z-ai",
      "model": "glm-4-7",
      "description": "System architect - Z.AI GLM-4.7 for database schemas, API structures, deployment architecture.",
      "tools": ["Read", "Write", "FunctionCall"],
      "maxSteps": 15,
      "temperature": 0.2,
      "topP": 0.9,
      "maxTokens": 8000,
      "priority": "CRITICAL",
      "concurrencySlot": 2,
      "thinking": {
        "enabled": true,
        "mode": "interleaved",
        "maxThinkingTokens": 5000
      }
    },
    {
      "name": "backend-engineer",
      "mode": "subagent",
      "provider": "groq",
      "model": "llama-3.3-70b-versatile",
      "modelAlternative": "mixtral-8x7b-32768",
      "description": "Backend implementation - Groq Llama 3.3 for fast server logic, APIs, database queries.",
      "tools": ["Read", "Write", "Bash"],
      "maxSteps": 18,
      "temperature": 0.3,
      "topP": 0.95,
      "maxTokens": 10000,
      "priority": "HIGH",
      "concurrencySlot": 3,
      "thinking": {
        "enabled": false
      }
    },
    {
      "name": "frontend-engineer",
      "mode": "subagent",
      "provider": "groq",
      "model": "llama-3.3-70b-versatile",
      "modelAlternative": "mixtral-8x7b-32768",
      "description": "Frontend implementation - Groq Llama 3.3 for fast React/Vue component generation.",
      "tools": ["Read", "Write", "Bash"],
      "maxSteps": 16,
      "temperature": 0.3,
      "topP": 0.95,
      "maxTokens": 10000,
      "priority": "HIGH",
      "concurrencySlot": 4,
      "thinking": {
        "enabled": false
      }
    },
    {
      "name": "qa-specialist",
      "mode": "subagent",
      "provider": "z-ai",
      "model": "glm-4-6v",
      "description": "QA and testing - Z.AI GLM-4.6V for test design and coverage analysis.",
      "tools": ["Read", "Write", "Bash"],
      "maxSteps": 14,
      "temperature": 0.1,
      "topP": 0.85,
      "maxTokens": 6000,
      "priority": "HIGH",
      "concurrencySlot": 5,
      "thinking": {
        "enabled": false
      }
    },
    {
      "name": "devops-engineer",
      "mode": "subagent",
      "provider": "groq",
      "model": "mixtral-8x7b-32768",
      "modelAlternative": "llama-3.3-70b-versatile",
      "description": "DevOps and deployment - Groq Mixtral for Docker, Kubernetes, CI/CD.",
      "tools": ["Read", "Write", "Bash"],
      "maxSteps": 14,
      "temperature": 0.2,
      "topP": 0.9,
      "maxTokens": 7000,
      "priority": "MEDIUM",
      "concurrencySlot": 6,
      "thinking": {
        "enabled": false
      }
    },
    {
      "name": "documentation-writer",
      "mode": "subagent",
      "provider": "groq",
      "model": "llama-3.3-70b-versatile",
      "modelAlternative": "mixtral-8x7b-32768",
      "description": "Documentation and API docs - Groq Llama 3.3 for README, API docs, comments.",
      "tools": ["Read", "Write"],
      "maxSteps": 10,
      "temperature": 0.2,
      "topP": 0.85,
      "maxTokens": 5000,
      "priority": "MEDIUM",
      "concurrencySlot": 7,
      "thinking": {
        "enabled": false
      }
    }
  ],
  "workflow": {
    "defaultAgent": "orchestrator-primary",
    "executionStrategy": "parallel-with-coordination",
    "maxParallelAgents": 7,
    "stateManagement": {
      "persistenceFile": "ORCHESTRATION_STATE.json",
      "savepointInterval": 60,
      "resumeOnInterrupt": true,
      "contextWindow": 128000
    },
    "concurrencyControl": {
      "z_ai": {
        "glm47_maxConcurrent": 5,
        "glm45_maxConcurrent": 10,
        "glm46v_maxConcurrent": 10
      },
      "groq": {
        "maxConcurrent": "unlimited"
      },
      "totalMaxConcurrent": 7,
      "queueStrategy": "priority-based-with-provider-affinity",
      "priorityOrder": ["CRITICAL", "HIGH", "MEDIUM"]
    }
  }
}
